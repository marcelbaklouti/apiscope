{
  "name": "@apiscope/hono",
  "version": "0.0.0",
  "license": "MIT",
  "description": "Hono adapter for apiscope (Node, Bun, Deno, Edge)",
  "repository": { "type": "git", "url": "git+https://github.com/marcelbaklouti/apiscope.git", "directory": "packages/hono" },
  "homepage": "https://github.com/marcelbaklouti/apiscope#readme",
  "bugs": "https://github.com/marcelbaklouti/apiscope/issues",
  "keywords": ["apiscope", "api", "monitoring", "load-testing", "devtools"],
  "publishConfig": { "access": "public" },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "smoke:bun": "bun run scripts/bun-smoke.ts"
  },
  "peerDependencies": {
    "hono": ">=4.0.0"
  },
  "dependencies": {
    "@apiscope/core": "workspace:*"
  },
  "devDependencies": {
    "@apiscope/collector": "workspace:*",
    "hono": "^4.12.27",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  }
}
