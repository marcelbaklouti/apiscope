{
  "name": "@apiscope/core",
  "version": "0.1.0",
  "license": "MIT",
  "description": "Span model and wire protocol for apiscope",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/marcelbaklouti/apiscope.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/marcelbaklouti/apiscope#readme",
  "bugs": "https://github.com/marcelbaklouti/apiscope/issues",
  "keywords": [
    "apiscope",
    "api",
    "monitoring",
    "load-testing",
    "devtools"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "fast-check": "^4.8.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  }
}
