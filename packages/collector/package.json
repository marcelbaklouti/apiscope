{
  "name": "@apiscope/collector",
  "version": "0.0.0",
  "license": "MIT",
  "description": "Local collector daemon with SQLite store and live streaming",
  "repository": { "type": "git", "url": "git+https://github.com/marcelbaklouti/apiscope.git", "directory": "packages/collector" },
  "homepage": "https://github.com/marcelbaklouti/apiscope#readme",
  "bugs": "https://github.com/marcelbaklouti/apiscope/issues",
  "keywords": ["apiscope", "api", "monitoring", "load-testing", "devtools"],
  "publishConfig": { "access": "public" },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./testing": {
      "types": "./dist/testing/store-conformance.d.ts",
      "import": "./dist/testing/store-conformance.js",
      "require": "./dist/testing/store-conformance.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@apiscope/core": "workspace:*",
    "@apiscope/load": "workspace:*",
    "argon2": "^0.44.0",
    "better-sqlite3": "^12.11.1",
    "cookie": "^2.0.1",
    "jose": "^6.2.3",
    "openid-client": "^6.8.4",
    "ws": "^8.21.0"
  },
  "optionalDependencies": {
    "@apiscope/store-clickhouse": "workspace:*"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.1.0",
    "@types/ws": "^8.18.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  }
}
