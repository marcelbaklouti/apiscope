  },
  "peerDependencies": {
    "next": ">=15.0.0"
  },
  "devDependencies": {
    "@apiscope/collector": "workspace:*",
    "@types/node": "^26.1.0",
    "next": "^16.2.10",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  }
