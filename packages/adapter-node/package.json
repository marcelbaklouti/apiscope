{
  "name": "@apiscope/adapter-node",
  "version": "0.0.0",
  "license": "MIT",
  "description": "Shared Node.js adapter runtime with span context and undici capture",
  "repository": { "type": "git", "url": "git+https://github.com/marcelbaklouti/apiscope.git", "directory": "packages/adapter-node" },
  "homepage": "https://github.com/marcelbaklouti/apiscope#readme",
  "bugs": "https://github.com/marcelbaklouti/apiscope/issues",
  "keywords": ["apiscope", "api", "monitoring", "load-testing", "devtools"],
  "publishConfig": { "access": "public" },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@apiscope/core": "workspace:*",
    "ws": "^8.21.0"
  },
  "peerDependencies": {
    "@prisma/instrumentation": "^7.8.0",
    "better-sqlite3": "^12.11.1",
    "mongodb": "^7.4.0",
    "mysql2": "^3.22.5",
    "pg": "^8.22.0"
  },
  "peerDependenciesMeta": {
    "@prisma/instrumentation": { "optional": true },
    "better-sqlite3": { "optional": true },
    "mongodb": { "optional": true },
    "mysql2": { "optional": true },
    "pg": { "optional": true }
  },
  "devDependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/sdk-trace-base": "^2.2.0",
    "@prisma/instrumentation": "^7.8.0",
    "@testcontainers/mongodb": "^12.0.4",
    "@testcontainers/mysql": "^12.0.4",
    "@testcontainers/postgresql": "^12.0.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.1.0",
    "@types/pg": "^8.20.0",
    "@types/ws": "^8.18.1",
    "@apiscope/collector": "workspace:*",
    "better-sqlite3": "^12.11.1",
    "mongodb": "^7.4.0",
    "mysql2": "^3.22.5",
    "pg": "^8.22.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  }
}
